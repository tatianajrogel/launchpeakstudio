2c:T416,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does pricing work?","acceptedAnswer":{"@type":"Answer","text":"Most projects are fixed scope with clear ranges. Design starts from $4k, web from $6k, and mobile from $9k. We send a simple proposal after our discovery call."}},{"@type":"Question","name":"How long does a project take?","acceptedAnswer":{"@type":"Answer","text":"A focused landing page can take two weeks. A full product design and build usually runs six to twelve weeks depending on scope."}},{"@type":"Question","name":"Do you work with global clients?","acceptedAnswer":{"@type":"Answer","text":"Yes. We are based in Portland, Oregon and work with clients across the US and around the world. Async friendly and timezone flexible."}},{"@type":"Question","name":"What is it like to work together?","acceptedAnswer":{"@type":"Answer","text":"Friendly, clear, and fast. You get one partner who designs and builds, weekly updates, and no jargon. We treat your product like our own."}}]}14:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2c"}}]
